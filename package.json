{
  "name": "@wearegood/good-utilities",
  "version": "2.0.0",
  "description": "A collection of JavaScript utility functions",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./DOM/*": "./DOM/*/*.js",
    "./Events/*": "./Events/*/*.js",
    "./Storage/*": "./Storage/*/*.js",
    "./String/*": "./String/*/*.js",
    "./Array/*": "./Array/*/*.js",
    "./Async/*": "./Async/*/*.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goodcreative/good-utilities.git"
  },
  "author": "Jamie Boyd <jamie@wearegood.com> (https://www.wearegood.com)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/goodcreative/good-utilities/issues"
  },
  "homepage": "https://github.com/goodcreative/good-utilities#readme",
  "devDependencies": {
    "@vitest/coverage-v8": "^2.0.0",
    "jsdom": "^25.0.0",
    "vitest": "^2.0.0"
  }
}
